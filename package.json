{
  "name": "@annoto/playkit-plugin-loader",
  "version": "0.1.0",
  "private": true,
  "description": "Thin Kaltura Player v7 (Playkit) wrapper plugin (annoto-loader) that loads the Annoto plugin so Annoto can be enabled via a Kaltura uiConf — including the IFrame embed. Anonymous-only.",
  "main": "dist/playkit-plugin-loader.js",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "serve:demo": "http-server -p 8080 -c-1 ."
  },
  "keywords": [
    "kaltura",
    "playkit",
    "playkit-js",
    "annoto",
    "plugin",
    "video"
  ],
  "license": "MIT",
  "peerDependencies": {
    "kaltura-player-js": "*"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "webpack": "^5.107.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.0.0"
  }
}
